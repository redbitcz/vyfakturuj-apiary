## Odeslání faktury e-mailem [/invoice/{id}/do/send-mail/]

<table>
    <tr>
        <th>Klíč</th>
        <th>Typ</th>
        <th>Popis</th>
        <th>Práva</th>
    </tr>
    <tr>
        <td>type</td>
        <td>int</td>
        <td>Typ e-mailu
        <blockquote>
            <code>1</code> Nový doklad<br>
            <code>2</code> Upomínka<br>
            <code>3</code> Doklad byl uhrazen
        </blockquote></td>
        <td>R/W</td>
    </tr>
    <tr>
        <td>to</td>
        <td>string255</td>
        <td>Adresát(i) např: "demo1@vyfakturuj.cz, demo2@vyfakturuj.cz"</td>
        <td>R/W</td>
    </tr>
    <tr>
        <td>cc</td>
        <td>string255</td>
        <td>Kopie</td>
        <td>R/W</td>
    </tr>
    <tr>
        <td>bcc</td>
        <td>string255</td>
        <td>Slepá kopie</td>
        <td>R/W</td>
    </tr>
    <tr>
        <td>subject (povinné)</td>
        <td>string255</td>
        <td>Předmět e-mailu</td>
        <td>R/W</td>
    </tr>
    <tr>
        <td>body</td>
        <td>text</td>
        <td>Obsah e-mailu</td>
        <td>R/W</td>
    </tr>
    <tr>
        <td>pdfAttachment</td>
        <td>bool</td>
        <td>Má se zaslat doklad jako PDF v příloze</td>
        <td>R/W</td>
    </tr>
    <tr>
        <td>test</td>
        <td>bool</td>
        <td>Slouží k otestování obsahu e-mailu. E-mail nebude odeslán.</td>
        <td>W</td>
    </tr>
    <tr>
        <td>additionalAttachments</td>
        <td>array</td>
        <td>Dodatečné přílohy k odeslání e-mailem. Maximální celková velikost všech příloh je 10MB</td>
        <td>R/W</td>
    </tr>
</table>

